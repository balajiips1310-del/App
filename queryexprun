def main():
    try:
        print("Starting MAIN execution")

        # ====================================================
        # PHASE 1: PARSE CONFIG
        # ====================================================
        try:
            print("[PHASE 1] Parsing config...")

            config = json.loads(export_config)

            export_name         = config.get("ExportName")
            export_type         = config.get("ExportType")
            watermark_column    = config.get("WatermarkColumn")
            target_source       = config.get("TargetSource")
            target_identifier   = config.get("TargetIdentifier")
            filters_json        = config.get("FiltersJson")
            filter_logic        = config.get("FilterLogic")
            filter_expression   = config.get("FilterExpression")
            column_mappings     = config.get("ColumnMappingsJson")
            static_metadata     = config.get("StaticMetadataJson")
            last_exported_at    = config.get("LastExportedAt")

            export_id           = config.get("ExportId")
            export_run_id       = config.get("ExportRunId")
            apply_suppression   = config.get("ApplySuppressionRules")

            print(f"Config parsed: {export_name}")

        except Exception as e:
            raise Exception(f"CONFIG_PARSE: {str(e)}")

        # ====================================================
        # PHASE 2: READ DATA
        # ====================================================
        try:
            print("[PHASE 2] Reading data...")
            df = spark.table(table_name)
            print("Data loaded")
        except Exception as e:
            raise Exception(f"READ_DATA: {str(e)}")

        # ====================================================
        # PHASE 4: APPLY FILTERS
        # ====================================================
        try:
            print("[PHASE 4] Applying filters...")

            filters = safe_json(filters_json)
            df_filter_excluded = None
            combined = None

            if filters:
                conditions = []

                for f_item in filters:
                    col_name = f_item.get("column")
                    operator = f_item.get("operator")
                    value    = f_item.get("value")

                    if operator == "equals":
                        conditions.append(F.col(col_name) == value)
                    elif operator == "not equals":
                        conditions.append(F.col(col_name) != value)
                    elif operator == "contains":
                        conditions.append(F.col(col_name).contains(value))
                    elif operator == "starts with":
                        conditions.append(F.col(col_name).startswith(value))
                    elif operator == "is empty":
                        conditions.append(F.col(col_name).isNull() | (F.col(col_name) == ""))
                    elif operator == "is not empty":
                        conditions.append(F.col(col_name).isNotNull() & (F.col(col_name) != ""))
                    elif operator == "is in":
                        values = [v.strip() for v in str(value).split(",")]
                        conditions.append(F.col(col_name).isin(values))
                    elif operator in (">", ">=", "<", "<=", "=", "!="):
                        conditions.append(F.expr(f"`{col_name}` {operator} '{value}'"))
                    elif operator == "between":
                        vals = [v.strip() for v in str(value).split(",")]
                        conditions.append(F.col(col_name).between(vals[0], vals[1]))
                    elif operator == "before":
                        conditions.append(F.col(col_name) < value)
                    elif operator == "after":
                        conditions.append(F.col(col_name) > value)
                    elif operator == "is within":
                        import re
                        match = re.search(r"(\d+)", str(value))
                        if match:
                            days = int(match.group(1))
                            conditions.append(F.col(col_name) >= F.date_sub(F.current_date(), days))

                if conditions:
                    if filter_logic == "And":
                        combined = conditions[0]
                        for c in conditions[1:]:
                            combined = combined & c
                    elif filter_logic == "Or":
                        combined = conditions[0]
                        for c in conditions[1:]:
                            combined = combined | c
                    elif filter_logic == "Custom" and filter_expression:
                        combined = F.expr(filter_expression)

                if combined is not None:
                    df_filter_excluded = df.filter(~combined)\
                        .withColumn("SuppressionCategory", F.lit("ExportFilter"))
                    df = df.filter(combined)

        except Exception as e:
            raise Exception(f"FILTERING: {str(e)}")

        # ====================================================
        # PHASE 4.5: SUPPRESSION
        # ====================================================
        try:
            df_supp_excluded = None
            encrypted_columns = set()

            if apply_suppression and str(apply_suppression).lower() == "true":
                from your_encryption_package import decrypt
                from pyspark.sql.functions import udf
                from pyspark.sql.types import StringType

                rules_df = spark.table("segmentation.suppression_rules") \
                    .filter(F.col("is_active") == True)

                rules = rules_df.collect()

                if rules:

                    @udf(StringType())
                    def decrypt_udf(val):
                        if val is None:
                            return None
                        try:
                            return decrypt(val)
                        except:
                            return None

                    df_columns = set(df.columns)

                    for rule in rules:
                        if rule["is_encrypted"] and rule["column"] in df_columns:
                            encrypted_columns.add(rule["column"])

                    for col_name in encrypted_columns:
                        df = df.withColumn(f"_dec_{col_name}", decrypt_udf(F.col(col_name)))

                    supp_conditions = []

                    for rule in rules:
                        if rule["column"] not in df_columns:
                            continue

                        col_ref = f"_dec_{rule['column']}" if rule["is_encrypted"] else rule["column"]
                        op = rule["operator"]
                        val = rule["value"]

                        if op == "in":
                            vals = [v.strip() for v in val.split(";")]
                            supp_conditions.append(~F.col(col_ref).isin(vals))
                        elif op == "containsAny":
                            import re as _re
                            patterns = [_re.escape(v.strip()) for v in val.split(";")]
                            regex = "|".join(patterns)
                            supp_conditions.append(~F.col(col_ref).rlike(regex))
                        elif op == "contains":
                            supp_conditions.append(~F.col(col_ref).contains(val))
                        elif op == "notContains":
                            supp_conditions.append(F.col(col_ref).isNotNull() & F.col(col_ref).contains(val))
                        elif op == "equals":
                            supp_conditions.append(F.col(col_ref) != val)
                        elif op == "notEquals":
                            supp_conditions.append(F.col(col_ref) == val)
                        elif op == "startsWith":
                            supp_conditions.append(~F.col(col_ref).startswith(val))
                        elif op == "isEmpty":
                            supp_conditions.append(F.col(col_ref).isNotNull() & (F.col(col_ref) != ""))

                    if supp_conditions:
                        combined_supp = supp_conditions[0]
                        for c in supp_conditions[1:]:
                            combined_supp = combined_supp & c

                        df_clean = df.filter(combined_supp)
                        df_excluded = df.filter(~combined_supp)

                        category_exprs = []

                        for rule in rules:
                            if rule["column"] not in df_columns:
                                continue

                            col_ref = f"_dec_{rule['column']}" if rule["is_encrypted"] else rule["column"]
                            op = rule["operator"]
                            val = rule["value"]
                            cat = rule["category"]

                            if op == "contains":
                                match_cond = F.col(col_ref).contains(val)
                            else:
                                match_cond = F.col(col_ref) == val

                            category_exprs.append(F.when(match_cond, F.lit(cat)))

                        df_excluded = df_excluded.withColumn(
                            "SuppressionCategory",
                            F.concat_ws(";", *category_exprs)
                        )

                        for col_name in encrypted_columns:
                            df_excluded = df_excluded.withColumn(col_name, F.col(f"_dec_{col_name}")).drop(f"_dec_{col_name}")

                        df_supp_excluded = df_excluded
                    else:
                        df_clean = df

                    for col_name in encrypted_columns:
                        df_clean = df_clean.withColumn(col_name, F.col(f"_dec_{col_name}")).drop(f"_dec_{col_name}")

                    df = df_clean

        except Exception as e:
            raise Exception(f"SUPPRESSION: {str(e)}")
        


        # ====================================================
        # PHASE 4.6: WRITE EXCLUSION CSV
        # ====================================================
        try:
            print("[PHASE 4.6] Writing exclusion CSV...")

            excl_parts = []

            if df_filter_excluded is not None and df_filter_excluded.count() > 0:
                excl_parts.append(df_filter_excluded)

            if df_supp_excluded is not None and df_supp_excluded.count() > 0:
                excl_parts.append(df_supp_excluded)

            if excl_parts:
                from functools import reduce

                df_all_excluded = reduce(
                    lambda a, b: a.unionByName(b, allowMissingColumns=True),
                    excl_parts
                )

                df_excl_output = df_all_excluded.select(
                    F.lit(export_id).alias("ExportId"),
                    F.lit(export_run_id).alias("ExportRunId"),
                    *[F.col(c) for c in df_all_excluded.columns if c != "SuppressionCategory"],
                    F.col("SuppressionCategory"),
                    F.current_timestamp().alias("ExcludedAt")
                )

                timestamp_str_excl = datetime.utcnow().strftime("%Y%m%d_%H%M%S")

                excl_filename = f"{export_name}_exclusions_{timestamp_str_excl}.csv"

                base_url = f"abfss://audiences@segmentationexports.dfs.core.windows.net"

                excl_temp = f"{base_url}/segment-exports/_temp/excl_{export_name}_{timestamp_str_excl}"

                exclusion_blob_path = f"{base_url}/segment-exports/{target_source}/{target_identifier}/exclusions/{excl_filename}"

                # Write temp
                df_excl_output.coalesce(1).write \
                    .option("header", "true") \
                    .mode("overwrite") \
                    .csv(excl_temp)

                # Move part file
                files = mssparkutils.fs.ls(excl_temp)
                part_file = [f.path for f in files if "part-" in f.name][0]

                mssparkutils.fs.mv(part_file, exclusion_blob_path, True)
                mssparkutils.fs.rm(excl_temp, True)

                print(f"Exclusion file created: {exclusion_blob_path}")

        except Exception as e:
            raise Exception(f"EXCLUSION_WRITE: {str(e)}")

        # ====================================================
        # PHASE 5: COLUMN MAPPING
        # ====================================================
        try:
            mappings = safe_json(column_mappings)
            select_exprs = []
            available_cols = set(df.columns)

            if mappings:
                for m in mappings:
                    src = m.get("sourceColumn")
                    tgt = m.get("targetColumn")

                    if not src or src not in available_cols:
                        select_exprs.append(F.lit(None).cast("string").alias(tgt))
                    else:
                        select_exprs.append(F.col(src).alias(tgt))

                df_export = df.select(select_exprs)
            else:
                df_export = df

        except Exception as e:
            raise Exception(f"COLUMN_MAPPING: {str(e)}")

        # ====================================================
        # PHASE 6: STATIC METADATA
        # ====================================================
        try:
            statics = safe_json(static_metadata)
            if statics:
                for s in statics:
                    df_export = df_export.withColumn(
                        s.get("destinationColumn"),
                        F.lit(s.get("staticValue"))
                    )
        except Exception as e:
            raise Exception(f"STATIC_METADATA: {str(e)}")

        # ====================================================
        # PHASE 7: WRITE OUTPUT
        # ====================================================
        try:
            timestamp = datetime.utcnow().strftime("%Y%m%d_%H%M%S")

            temp_path = f"abfss://{CONTAINER_NAME}@{STORAGE_ACCOUNT}.dfs.core.windows.net/temp/{export_name}_{timestamp}"
            final_path = f"abfss://{CONTAINER_NAME}@{STORAGE_ACCOUNT}.dfs.core.windows.net/{target_source}/{target_identifier}/{export_name}_{timestamp}.csv"

            df_export.coalesce(1).write.option("header", "true").mode("overwrite").csv(temp_path)

            files = mssparkutils.fs.ls(temp_path)
            part_file = [f.path for f in files if "part-" in f.name][0]

            mssparkutils.fs.mv(part_file, final_path, True)
            mssparkutils.fs.rm(temp_path, True)

        except Exception as e:
            raise Exception(f"WRITE_OUTPUT: {str(e)}")

        # ====================================================
        # PHASE 8: FINAL OUTPUT
        # ====================================================
        try:
            file_size = 0
            try:
                file_info = mssparkutils.fs.ls(final_path)
                if file_info:
                    file_size = file_info[0].size
            except Exception as e:
                print("File size fetch failed:", str(e))

            return {
                "IsSuccess": 1,
                "total_records": df_export.count(),
                "file_size_bytes": file_size,
                "blob_path": final_path
            }

        except Exception as e:
            raise Exception(f"FINAL_RESPONSE: {str(e)}")

    except Exception as e:
        print("MAIN FAILED")
        return {
            "IsSuccess": 0,
            "error": str(e)
        }
